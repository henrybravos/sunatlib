# .env.example — Copia esto como .env y completá con valores reales.
# NUNCA commitear el .env real. Está en .gitignore.

# RUC del emisor electrónico
SUNAT_RUC=20XXXXXXXXXXX

# Credenciales SOL para SUNAT beta (siempre MODDATOS en beta)
SUNAT_SOL_USUARIO=MODDATOS
SUNAT_SOL_CLAVE=MODDATOS

# Certificado digital para firma (absoluto, fuera del repo)
SUNAT_CERT_PATH=/ruta/a/tu/certificado.p12
SUNAT_CERT_PASS=tupassword
