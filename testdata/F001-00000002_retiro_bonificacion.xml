    <!-- TaxableAmount=0 porque LineExtensionAmount=0 (cliente paga 0) -->
    <!-- El TaxAmount=0 acá; el IGV absorbido se refleja solo a nivel de documento -->
    <!-- tipAfeIgv=15 (Bonificaciones) → TaxScheme=9996 (GRA), empresa absorbe IGV -->
    <!-- Para retiro, el TaxableAmount y TaxAmount en el ITEM deben reflejar el valor referencial -->
    <!-- aunque el cliente pague 0 (LineExtensionAmount=0) -->
